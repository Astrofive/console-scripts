(function clickLoop() {
    // Find the first button that says "Send Message"
    const button = Array.from(document.querySelectorAll('button'))
        .find(b => b.textContent.trim() === "Send Message");

    if (button) {
        button.click();
        setTimeout(clickLoop, 1000 / 30); // ~33ms (30 clicks/sec)
    } else {
        setTimeout(clickLoop, 2000);      // 2 second pause
    }
})();
